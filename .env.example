# Actual Budget Configuration
# Copy this file to .env and fill in your values

# Actual Budget Server URL
ACTUAL_SERVER_URL=http://localhost:5006

# Actual Budget Password
ACTUAL_PASSWORD=your-password-here

# Actual Budget Sync ID (found in Settings > Show advanced settings > Sync ID)
ACTUAL_SYNC_ID=your-sync-id-here

# Data directory for local cache
ACTUAL_DATA_DIR=../actual-data

# Optional: Pre-configure account ID to skip interactive selection
# ACCOUNT_ID=your-account-id-here

# S3 Configuration (required for poller/Docker mode)
S3_BUCKET_NAME=your-bucket-name
AWS_REGION=ap-south-1

# Polling interval in milliseconds (default: 300000 = 5 minutes)
# POLL_INTERVAL_MS=300000

# Default category group for auto-created categories
# DEFAULT_CATEGORY_GROUP=Usual Expenses